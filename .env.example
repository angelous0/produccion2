# Backend — Base de datos principal (producción)
DATABASE_URL=postgres://usuario:password@host:5432/basedatos?sslmode=disable

# Base de datos de muestras (usada por scripts de seed y migrations)
MUESTRA_DATABASE_URL=postgres://user:pass@host:5432/datos?sslmode=disable

# JWT — OBLIGATORIO, sin default. Generar con: openssl rand -hex 32
JWT_SECRET_KEY=

# CORS — orígenes permitidos, separados por coma. Default: * (solo para desarrollo)
CORS_ORIGINS=https://tu-frontend.easypanel.host

# Frontend (se pasa como build arg en Docker)
REACT_APP_BACKEND_URL=https://tu-backend-url.easypanel.host
